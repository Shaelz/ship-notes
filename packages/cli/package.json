{
  "name": "ship-notes",
  "version": "1.5.1",
  "description": "CLI tool for writing and publishing structured release notes",
  "author": "Shaelz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shaelz/ship-notes.git"
  },
  "keywords": ["changelog", "release-notes", "cli", "static-site"],
  "engines": { "node": ">=18" },
  "files": ["dist", "!dist/test"],
  "type": "module",
  "bin": {
    "ship-notes": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc",
    "test": "node --test dist/test/*.test.js"
  },
  "dependencies": {
    "@ship-notes/core": "workspace:*",
    "smol-toml": "^1.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.6.0",
    "undici-types": "^8.5.0"
  }
}
